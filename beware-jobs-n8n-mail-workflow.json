    {
      "parameters": {
        "jsCode": "const parts = $json.candidates?.[0]?.content?.parts || [];\nconst text = parts.filter((part) => typeof part.text === 'string').map((part) => part.text).join('\\n').trim();\nreturn [{ json: { reply: text || 'Mentor cevabi olusturulamadi.', message: 'AI cevabi hazir.' } }];"
      },
