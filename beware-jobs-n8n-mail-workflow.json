      "parameters": {
        "jsCode": "const parts = $json.candidates?.[0]?.content?.parts || [];\nconst text = parts.filter((part) => typeof part.text === 'string').map((part) => part.text).join('\\n').trim();\nconst safeText = text || 'Soru analizi olusturulamadi.';\nreturn [{ json: { report: safeText, html: `<div class=\"rounded-xl border border-black/10 bg-[#fffdf8] p-4 text-sm text-smoke whitespace-pre-line\">${safeText.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</div>`, message: 'AI analizi hazir.' } }];"
      },
      "id": "parse_report",
      "name": "Parse Report",
