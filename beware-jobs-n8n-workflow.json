        "respondWith": "json",
        "responseBody": "={\n  \"student_name\": \"{{$json.student_name}}\",\n  \"selected_career\": \"{{$json.selected_career}}\",\n  \"report\": \"{{$json.report}}\",\n  \"email_status\": \"Mail adimi baglanirsa otomatik gonderilebilir.\"\n}",
        "options": {}
      },
      "id": "respond_node",
      "name": "Return Analysis",
      "type": "n8n-nodes-base.respondToWebhook",
